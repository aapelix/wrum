{
  "name": "wrum",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "fmt": "turbo run fmt",
    "prepare": "husky",
    "build:server": "turbo run build --filter=server",
    "build:game": "turbo run build --filter=game",
    "start:server": "turbo run start --filter=server",
    "start:game": "turbo run start --filter=game"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "turbo": "^2.8.21"
  },
  "lint-staged": {
    "apps/**/*.{ts,tsx,js,jsx,mjs,cjs}": [
      "turbo run lint fmt --filter='./apps/*' --"
    ],
    "packages/**/*.*.{ts,tsx,js,jsx,mjs,cjs}": [
      "turbo run lint fmt --filter='./packages/*' --"
    ]
  },
  "packageManager": "bun@1.3.11"
}
